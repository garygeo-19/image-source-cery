{
  "judge": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "minScore": 0.7,
    "apiKeyEnv": "OPENAI_API_KEY"
  },
  "pipeline": [
    { "provider": "wikimedia" },
    { "provider": "inaturalist", "license": ["cc0", "cc-by", "cc-by-nc"] },
    { "provider": "loc" },
    { "provider": "unsplash", "apiKeyEnv": "UNSPLASH_ACCESS_KEY" },
    { "provider": "generate", "model": "gpt-image-1", "size": "1024x1024", "quality": "medium", "apiKeyEnv": "OPENAI_API_KEY" }
  ]
}
